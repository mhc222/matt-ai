# --- Required: GoHighLevel public API ---
# Create a Private Integration Token in GHL:
#   Settings -> Private Integrations -> Create New
# Give it every scope you want the CLI to use (contacts, workflows, etc).
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your GHL location/sub-account ID (the long string in your GHL URL).
GHL_LOCATION_ID=YOUR_LOCATION_ID

# --- Optional but recommended: Firebase token for the "internal API" ---
# The public GHL API can't *create* workflows, only read them.
# To create/update workflows you need a Firebase refresh token.
# Get one with the bundled Chrome extension:
#   1. Load chrome-extension/ as an unpacked extension in Chrome
#   2. Open any app.gohighlevel.com page while logged in
#   3. Click the extension icon -> "Grab Refresh Token" -> "Copy to Clipboard"
#   4. Paste here:
GHL_FIREBASE_REFRESH_TOKEN=
